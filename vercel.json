{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/roundrobin-dbedit.php",   "dest": "/api/roundrobin-dbedit.php" },
    { "src": "/roundrobin-event.php",   "dest": "/api/roundrobin-event.php" },
    { "src": "/roundrobin-member.php",  "dest": "/api/roundrobin-member.php" },
    { "src": "/(.*)", "dest": "/api/roundrobin.php" }
  ]
}
